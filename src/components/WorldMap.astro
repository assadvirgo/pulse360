---
/**
 * Interactive SVG world-map with clickable country outlines.
 * Each country highlights on hover and links to /country/<code>.
 * Countries with articles get an accent fill; others stay muted.
 * Uses simplified equirectangular projection paths.
 */
interface Props {
  /** Set of country codes that have at least one article */
  activeCodes?: Set<string>;
}

const { activeCodes = new Set() } = Astro.props;

// Simplified SVG paths for each country (equirectangular projection, viewBox 0 0 1000 500)
const countries: { code: string; name: string; d: string }[] = [
  // North America
  { code: 'CA', name: 'Canada', d: 'M111 114 L156 115 L211 114 L236 114 L314 125 L347 119 L333 83 L280 58 L236 47 L170 50 L111 56Z' },
  { code: 'US', name: 'United States', d: 'M156 115 L211 114 L236 114 L280 119 L314 125 L300 139 L292 153 L278 181 L250 169 L231 178 L200 172 L175 160 L156 133Z' },
  { code: 'MX', name: 'Mexico', d: 'M175 160 L200 172 L231 178 L236 186 L258 208 L244 211 L228 206 L208 197 L194 186Z' },
  { code: 'CU', name: 'Cuba', d: 'M267 192 L286 189 L294 192 L281 197Z' },
  // South America
  { code: 'CO', name: 'Colombia', d: 'M286 217 L300 211 L314 217 L319 231 L311 244 L297 247 L283 239Z' },
  { code: 'BR', name: 'Brazil', d: 'M319 250 L333 236 L358 236 L392 247 L403 258 L400 278 L389 297 L372 314 L356 336 L342 325 L331 303 L319 283Z' },
  { code: 'AR', name: 'Argentina', d: 'M331 314 L342 325 L356 336 L350 358 L342 378 L331 389 L319 381 L314 361 L322 339Z' },
  // Europe
  { code: 'GB', name: 'United Kingdom', d: 'M486 106 L489 97 L494 89 L497 94 L500 100 L500 108 L494 111Z' },
  { code: 'FR', name: 'France', d: 'M486 117 L494 111 L506 108 L519 114 L519 125 L514 131 L503 133 L494 131Z' },
  { code: 'ES', name: 'Spain', d: 'M475 133 L494 131 L503 133 L506 139 L497 150 L483 150 L475 144Z' },
  { code: 'DE', name: 'Germany', d: 'M517 97 L528 94 L539 97 L542 106 L539 114 L528 117 L519 114 L517 106Z' },
  { code: 'IT', name: 'Italy', d: 'M519 122 L525 119 L531 122 L536 131 L533 142 L528 150 L522 147 L519 136Z' },
  { code: 'PL', name: 'Poland', d: 'M536 97 L547 94 L558 97 L561 106 L556 114 L544 114 L536 108Z' },
  { code: 'UA', name: 'Ukraine', d: 'M561 103 L572 100 L589 100 L603 103 L608 111 L603 119 L589 122 L575 122 L561 117Z' },
  { code: 'RO', name: 'Romania', d: 'M556 117 L567 114 L578 117 L581 125 L575 131 L564 131 L556 125Z' },
  // Russia
  { code: 'RU', name: 'Russia', d: 'M578 97 L608 89 L647 86 L711 83 L778 83 L833 86 L875 92 L917 78 L958 72 L975 56 L936 47 L875 42 L778 42 L694 44 L625 50 L578 58 L569 72 L575 83Z' },
  // Middle East
  { code: 'TR', name: 'Turkey', d: 'M567 133 L578 128 L594 128 L611 131 L622 136 L622 144 L608 150 L589 150 L575 147 L567 142Z' },
  { code: 'IL', name: 'Israel', d: 'M594 156 L600 153 L603 158 L600 167 L594 167Z' },
  { code: 'SA', name: 'Saudi Arabia', d: 'M597 164 L611 158 L633 164 L647 178 L639 200 L622 206 L603 200 L597 186Z' },
  { code: 'AE', name: 'UAE', d: 'M639 181 L653 178 L658 183 L653 192 L642 192Z' },
  { code: 'IR', name: 'Iran', d: 'M622 136 L639 133 L658 136 L669 147 L669 172 L658 178 L642 178 L628 172 L622 158Z' },
  // Africa
  { code: 'EG', name: 'Egypt', d: 'M567 156 L589 153 L597 158 L597 183 L583 192 L567 189Z' },
