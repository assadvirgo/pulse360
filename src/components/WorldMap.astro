  { code: 'KE', name: 'Kenya', d: 'M600 236 L614 233 L622 239 L622 258 L614 264 L603 261 L600 250Z' },
  { code: 'ZA', name: 'South Africa', d: 'M550 311 L572 306 L589 308 L597 319 L592 339 L578 350 L558 350 L547 339 L547 325Z' },
  // Asia
  { code: 'PK', name: 'Pakistan', d: 'M669 144 L686 139 L700 144 L708 153 L706 167 L694 178 L678 178 L669 167Z' },
  { code: 'IN', name: 'India', d: 'M694 150 L711 144 L728 150 L742 167 L742 189 L731 208 L719 225 L706 225 L694 214 L686 194 L686 172Z' },
  { code: 'CN', name: 'China', d: 'M703 114 L742 103 L783 100 L831 103 L847 114 L842 136 L831 153 L814 167 L792 175 L769 178 L747 172 L722 164 L703 147Z' },
  { code: 'TH', name: 'Thailand', d: 'M775 189 L786 183 L794 189 L794 208 L789 222 L783 228 L775 217Z' },
  { code: 'JP', name: 'Japan', d: 'M878 122 L892 117 L900 122 L897 136 L889 153 L878 161 L872 156 L875 139Z' },
  { code: 'KR', name: 'South Korea', d: 'M856 139 L864 133 L872 139 L869 153 L861 158 L853 153Z' },
  { code: 'PH', name: 'Philippines', d: 'M833 192 L844 186 L853 192 L853 214 L847 225 L836 222 L831 211Z' },
  { code: 'ID', name: 'Indonesia', d: 'M764 236 L786 231 L808 233 L836 239 L869 247 L881 258 L864 267 L831 269 L800 264 L775 258 L764 250Z' },
  // Oceania
  { code: 'AU', name: 'Australia', d: 'M817 281 L856 275 L897 275 L925 281 L931 303 L925 325 L911 347 L889 356 L856 356 L831 347 L817 331 L814 306Z' },
  { code: 'NZ', name: 'New Zealand', d: 'M961 347 L972 339 L981 344 L983 361 L975 378 L967 375 L961 364Z' },
];
---

<div class="world-map-container w-full overflow-x-auto">
  <svg
    viewBox="0 0 1000 500"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full max-w-4xl mx-auto"
    role="img"
    aria-label="World map showing countries with news coverage"
    preserveAspectRatio="xMidYMid meet"
  >
    <!-- Ocean background -->
    <rect width="1000" height="500" fill="var(--color-surface)" rx="12" />

    <!-- Subtle grid / graticule lines -->
    <g opacity="0.06" stroke="var(--color-ink)">
      {/* Longitude lines every 30 degrees */}
      {Array.from({ length: 13 }, (_, i) => (
        <line x1={i * (1000 / 12)} y1="0" x2={i * (1000 / 12)} y2="500" stroke-width="0.5" />
      ))}
      {/* Latitude lines every 30 degrees */}
      {Array.from({ length: 7 }, (_, i) => (
        <line x1="0" y1={i * (500 / 6)} x2="1000" y2={i * (500 / 6)} stroke-width="0.5" />
      ))}
      {/* Equator slightly stronger */}
      <line x1="0" y1="250" x2="1000" y2="250" stroke-width="1" opacity="0.5" />
    </g>

    {/* Country shapes */}
    {countries.map(c => {
      const hasArticles = activeCodes.has(c.code);
      return (
        <a href={hasArticles ? `${import.meta.env.BASE_URL}country/${c.code}` : undefined} class:list={['map-country', { active: hasArticles, inactive: !hasArticles }]}>
          <title>{c.name}{hasArticles ? ' — click to view articles' : ''}</title>
          <path
            d={c.d}
            fill={hasArticles ? 'var(--color-accent)' : 'var(--color-border)'}
            opacity={hasArticles ? '0.65' : '0.3'}
            stroke={hasArticles ? 'var(--color-accent)' : 'var(--color-muted)'}
            stroke-width={hasArticles ? '1' : '0.5'}
            stroke-linejoin="round"
            class="transition-all duration-200"
          />
          {/* Country code label */}
          {(() => {
            // Calculate centroid from path bounding box
            const nums = c.d.match(/\d+(\.\d+)?/g)?.map(Number) ?? [];
            let sumX = 0, sumY = 0, count = 0;
            for (let i = 0; i < nums.length; i += 2) {
              sumX += nums[i]; sumY += nums[i + 1]; count++;
            }
            const cx = sumX / count;
            const cy = sumY / count;
            const size = count < 6 ? 8 : 10;
            return (
              <text
                x={cx}
                y={cy + 1}
                text-anchor="middle"
                dominant-baseline="central"
                font-size={size}
                font-weight={hasArticles ? '600' : '400'}
                fill={hasArticles ? 'white' : 'var(--color-muted)'}
                opacity={hasArticles ? '1' : '0.5'}
                class="pointer-events-none select-none"
                style="font-family: var(--font-ui)"
              >
                {c.code}
              </text>
            );
          })()}
        </a>
      );
    })}
  </svg>
</div>

<style>
  .map-country.active {
    cursor: pointer;
  }
  .map-country.active:hover path {
    opacity: 0.9 !important;
    fill: var(--color-accent);
    stroke: var(--color-accent);
    stroke-width: 2;
    filter: drop-shadow(0 0 6px var(--color-accent));
  }
  .map-country.active:hover text {
    fill: white;
    font-weight: 700;
  }
  .map-country.inactive {
    pointer-events: none;
  }
  .map-country.active:focus-visible path {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
