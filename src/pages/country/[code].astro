---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import CategoryNav from '../../components/CategoryNav.astro';
import { getReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const allArticles = await getCollection('news');
  const codeSet = new Set<string>();
  for (const a of allArticles) {
    if (a.data.countryCode) {
      codeSet.add(a.data.countryCode);
    }
  }
  return Array.from(codeSet).map((code) => ({ params: { code } }));
}

const { code } = Astro.params;
const allArticles = await getCollection('news');
const filtered = allArticles
  .filter((a) => a.data.countryCode === code)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Resolve country name from the first article, fallback to code
const countryName = filtered[0]?.data.country || code;

// Category counts for nav
const categoryCounts: Record<string, number> = {};
for (const a of filtered) {
  const cat = a.data.category;
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
}

// Other countries for sidebar navigation
const otherCountries: Record<string, { name: string; count: number }> = {};
for (const a of allArticles) {
  const c = a.data.countryCode;
  if (c && c !== code) {
    if (!otherCountries[c]) {
      otherCountries[c] = { name: a.data.country || c, count: 0 };
    }
    otherCountries[c].count++;
  }
}
const sortedOthers = Object.entries(otherCountries)
  .sort((a, b) => b[1].count - a[1].count)
  .slice(0, 15);
---

<BaseLayout title={`${countryName} News`} description={`Latest news from ${countryName} on pulse360.`}>
  <section class="max-w-6xl mx-auto px-6 pt-14 pb-6">
    <div class="flex items-center gap-4 mb-2">
      <a
        href={`${import.meta.env.BASE_URL}country`}
        class="inline-flex items-center gap-1 text-sm font-medium uppercase tracking-widest text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Countries
      </a>
      <div class="w-px h-4 bg-[var(--color-border)]"></div>
      <h1 class="text-xl sm:text-2xl font-bold text-[var(--color-ink)]" style="font-family: var(--font-prose)">
        {countryName}
      </h1>
      <span class="text-xs font-mono px-2 py-1 rounded bg-[var(--color-accent-soft)] text-[var(--color-accent)]">{code}</span>
    </div>
    <p class="text-sm text-[var(--color-muted)] mb-8 opacity-60">
      {filtered.length} article{filtered.length !== 1 ? 's' : ''} from {countryName}
    </p>

    <!-- Category breakdown for this country -->
    {Object.keys(categoryCounts).length > 1 && (
      <div class="mb-6 flex flex-wrap gap-2">
        {Object.entries(categoryCounts).sort((a, b) => b[1] - a[1]).map(([cat, count]) => (
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs border border-[var(--color-border)] text-[var(--color-muted)]">
            <span>{cat}</span>
            <span class="opacity-50 tabular-nums">{count}</span>
          </span>
        ))}
      </div>
    )}

    <!-- Articles grid -->
    {filtered.length === 0 ? (
      <div class="text-center py-24 text-[var(--color-muted)]">
        <p class="text-lg">No articles for {countryName} yet.</p>
        <p class="text-sm mt-2 opacity-60">Check back after the next research run.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {filtered.map((article) => (
          <ArticleCard
            id={article.id}
            slug={article.id}
            readingTime={getReadingTime(article.body ?? '')}
            {...article.data}
          />
        ))}
      </div>
    )}

    <!-- Other countries sidebar -->
    {sortedOthers.length > 0 && (
      <div class="mt-16">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="text-sm font-semibold uppercase tracking-widest text-[var(--color-muted)]">Other countries</h2>
          <div class="flex-1 h-px bg-[var(--color-border)]"></div>
          <a
            href={`${import.meta.env.BASE_URL}country`}
            class="text-xs text-[var(--color-accent)] hover:underline"
          >
            View all
          </a>
        </div>
        <div class="flex flex-wrap gap-2">
          {sortedOthers.map(([c, { name, count }]) => (
            <a
              href={`${import.meta.env.BASE_URL}country/${c}`}
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs border border-[var(--color-border)] text-[var(--color-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-accent-soft)] transition-all"
            >
              <span>{name}</span>
              <span class="opacity-50 tabular-nums">{count}</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
