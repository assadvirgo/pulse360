---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('news');
const sorted = allArticles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Archive" description="Every article pulse360 has ever published, newest first.">
  <section class="max-w-6xl mx-auto px-6 pt-14 pb-6">
    <!-- Header -->
    <div class="flex items-center gap-4 mb-2">
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="inline-flex items-center gap-1 text-sm font-medium uppercase tracking-widest text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Feed
      </a>
      <div class="w-px h-4 bg-[var(--color-border)]"></div>
      <h1 class="text-xl sm:text-2xl font-bold text-[var(--color-ink)]" style="font-family: var(--font-prose)">
        Archive
      </h1>
    </div>
    <p class="text-sm text-[var(--color-muted)] mb-10 opacity-60">
      {sorted.length} article{sorted.length !== 1 ? 's' : ''} — newest first
    </p>

    {sorted.length === 0 ? (
      <div class="text-center py-24 text-[var(--color-muted)]">
        <p>No articles yet. Check back soon.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="archive-grid">
        {sorted.map(article => (
          <ArticleCard id={article.id} slug={article.id} {...article.data} />
        ))}
      </div>

      <div class="mt-14 flex flex-col items-center gap-4">
        <p id="archive-count" class="text-xs text-[var(--color-muted)]"></p>
        <button
          id="load-more"
          class="hidden group inline-flex items-center gap-2 px-6 py-3 text-sm font-medium rounded-full border border-[var(--color-border)] text-[var(--color-muted)] hover:text-[var(--color-ink)] hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-accent-soft)] transition-all duration-200"
        >
          Load more
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-y-0.5 transition-transform"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
        </button>
        <p id="all-loaded" class="hidden text-xs text-[var(--color-muted)] opacity-40">You've reached the beginning.</p>
      </div>
    )}
  </section>
</BaseLayout>

<script>
  const PAGE_SIZE = 24;

  const allCards   = Array.from(document.querySelectorAll<HTMLElement>('#archive-grid article'));
  const countEl    = document.getElementById('archive-count');
  const loadMoreBtn = document.getElementById('load-more') as HTMLButtonElement | null;
  const allLoadedEl = document.getElementById('all-loaded');

  let page = 1;

  function render() {
    const showUpTo = page * PAGE_SIZE;
    allCards.forEach((article, i) => {
      (article as HTMLElement).style.display = i < showUpTo ? '' : 'none';
    });

    const visible = Math.min(allCards.length, showUpTo);
    const total   = allCards.length;

    if (countEl) {
      countEl.textContent = `Showing ${visible} of ${total}`;
    }

    const hasMore = visible < total;
    loadMoreBtn?.classList.toggle('hidden', !hasMore);
    allLoadedEl?.classList.toggle('hidden', hasMore);
  }

  render();

  loadMoreBtn?.addEventListener('click', () => {
    page++;
    render();
    // Scroll to first newly revealed card
    const firstNew = allCards[(page - 1) * PAGE_SIZE];
    firstNew?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
